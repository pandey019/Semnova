{
  "name": "semnova",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./memory": {
      "types": "./dist/stores/memory.d.ts",
      "import": "./dist/stores/memory.mjs",
      "require": "./dist/stores/memory.js"
    },
    "./pgvector": {
      "types": "./dist/stores/pgvector.d.ts",
      "import": "./dist/stores/pgvector.mjs",
      "require": "./dist/stores/pgvector.js"
    },
    "./sqlite": {
      "types": "./dist/stores/sqlite.d.ts",
      "import": "./dist/stores/sqlite.mjs",
      "require": "./dist/stores/sqlite.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "better-sqlite3": "^11.0.0 || ^12.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "better-sqlite3": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "keywords": [
    "semantic",
    "search",
    "vector",
    "embeddings",
    "ai",
    "pgvector",
    "sqlite",
    "local"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "commonjs",
  "dependencies": {
    "@huggingface/transformers": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "better-sqlite3": "^12.8.0",
    "pg": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
